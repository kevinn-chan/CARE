import numpy as np
import scipy.stats as stats

# =====================================================================
# HEURISTIC RISK MATRIX (THE PRIOR ASSUMPTIONS)
# In production, these multipliers are derived from empirical city data.
# They are exposed here as a configuration layer for transparency.
# =====================================================================
RISK_MATRIX = {
    "precinct_fundamentals": {
        # Derived via Z-Score Normalization of historical crime density vs city mean
        "High": 1.2,  # +20% expected anomaly baseline
        "Medium": 0.5,  # City average baseline
        "Low": 0.2  # -30% expected anomaly baseline
    },
    "temporal_macros": {
        # Derived via Poisson Arrival Rate ratios (λ_target / λ_baseline)
        "Night (2 AM - 5 AM)": 3.0,  # Historical 3x spike in unobserved incidents
        "Evening (6 PM - 1 AM)": 1.5,  # Elevated foot-traffic volatility
        "Day (6 AM - 5 PM)": 1.0  # The Reference State (Baseline)
    },
    "environmental_noise": {
        # Derived via Model Precision Decay (False Positive Rate under stress)
        "Heavy Rain/Storm": 2.5,  # Measured 2.5x increase in False Positives (Flattens Beta)
        "Fog/Low Visibility": 1.8,  # Measured 1.8x increase in False Positives
        "Clear": 1.0  # The Reference State (Baseline)
    },
    "event_catalysts": {
        # Simulates localized crowd density spikes from Eventbrite/City APIs
        "Protest/Riot": 4.0,
        "Concert/Sports (Crowds)": 2.0,
        "None": 1.0
    },
    "osint_sentiment": {
        # Multiplier applied if localized X/Telegram scraping detects panic keywords
        True: 2.5,
        False: 1.0
    }
}


def monte_carlo_sims(time, weather, precinct_risks="Medium", active_events="None", osint_spike=False, sims=10000):
    """
    Multimodal B-SVaR Engine: Generates Contextual Prior P(T) and VaR Threshold.
    """
    # 1. Fetch values strictly from the Risk Matrix
    base_rate = RISK_MATRIX["precinct_fundamentals"].get(precinct_risks, 0.5)
    time_mult = RISK_MATRIX["temporal_macros"].get(time, 1.0)
    event_mult = RISK_MATRIX["event_catalysts"].get(active_events, 1.0)
    osint_mult = RISK_MATRIX["osint_sentiment"].get(osint_spike, 1.0)

    noise_factor = RISK_MATRIX["environmental_noise"].get(weather, 1.0)

    # 2. Calculate the Total Arrival Rate (Alpha)
    total_arrival_rate = base_rate * time_mult * event_mult * osint_mult

    # 3. Parameterize the Beta Distribution
    # Alpha (a): Frequency of expected anomalies.
    # Beta (b): Strength of normalcy. High noise_factor decreases beta (increases skepticism).
    a = total_arrival_rate * noise_factor
    b = (20.0 / noise_factor)

    # 4. Monte Carlo Simulation
    simulations = np.random.beta(a, b, size=sims)

    # Extract simulated Mean (Prior) and 95th percentile (VaR Threshold)
    prior_prob = float(np.mean(simulations))
    var_95 = float(np.percentile(simulations, 95))

    return prior_prob, var_95


def calculate_bayesian_posterior(prior, likelihood, false_positive_rate=0.10):
    """
    Calculates P(T|V) using Bayes' Theorem.
    """
    numerator = likelihood * prior
    denominator = numerator + (false_positive_rate * (1.0 - prior))
    return numerator / denominator if denominator > 0 else 0.0


